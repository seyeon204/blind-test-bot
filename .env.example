# NOTE: 값 뒤에 인라인 주석(KEY=value # comment) 사용 금지.
#       pydantic-settings가 주석을 값의 일부로 읽어 파싱 오류가 발생합니다.
#       주석은 반드시 별도 라인(# ...)에 작성하세요.

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI / Codex API ────────────────────────────────────────────────────────
CODEX_API_KEY=sk-...
CODEX_MODEL=gpt-4o-mini

# ── Global LLM provider ───────────────────────────────────────────────────────
# "anthropic" | "claude-api" | "claude-cli" | "gemini-api" | "gemini-cli" | "codex-api" | "codex-cli"
# "anthropic" and "claude-api" are equivalent.
LLM_PROVIDER=anthropic

# ── Per-phase provider overrides (empty = inherit from LLM_PROVIDER) ──────────
# Valid values: "" | "anthropic" | "claude-api" | "claude-cli"
#                 | "gemini-api" | "gemini-cli"
#                 | "codex-api"  | "codex-cli"
#
# ai-recom 프리셋 추천 구성 (API 요청에서 phase*_provider=ai-recom 사용 시 참고):
#   Phase 0: gemini-api  ← 문서/PDF 파싱 (env로만 제어)
#   Phase 1: claude-cli  ← 테스트 플랜 수립
#   Phase 2: gemini-cli  ← TC 생성
#   Phase 3: gemini-cli  ← AI 검증
PHASE0_PROVIDER=gemini-api
PHASE1_PROVIDER=
PHASE2A_PROVIDER=
PHASE2B_PROVIDER=
PHASE3_PROVIDER=

# ── Claude model selection ────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TC_MODEL=claude-haiku-4-5-20251001

# ── Anthropic rate limiting ───────────────────────────────────────────────────
ANTHROPIC_RPM=40
TC_BATCH_DELAY_SECONDS=10

# ── HTTP execution ────────────────────────────────────────────────────────────
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT_SECONDS=30

# ── Misc ──────────────────────────────────────────────────────────────────────
RUN_TTL_HOURS=24
AI_VALIDATE_TIMEOUT_SECONDS=120
MAX_RESPONSE_BODY_BYTES=10240
